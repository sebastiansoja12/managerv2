    <changeSet id="create-mobile-installed-apps-table-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="mobile_installed_apps"/>
            </not>
        </preConditions>

        <createTable tableName="mobile_installed_apps">
            <column name="device_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="app_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="mobile_installed_apps"
                       columnNames="device_id, app_name"
                       constraintName="pk_mobile_installed_apps"/>

        <addForeignKeyConstraint baseTableName="mobile_installed_apps"
                                 baseColumnNames="device_id"
                                 referencedTableName="mobiles"
                                 referencedColumnNames="device_id"
                                 constraintName="fk_mobile_installed_apps_mobile"/>
    </changeSet>

