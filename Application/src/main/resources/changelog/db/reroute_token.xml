<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.7.xsd">

    <changeSet id="create-reroute-token-table-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="reroute_token"/>
            </not>
        </preConditions>

        <createTable tableName="reroute_token">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP"/>
            <column name="timeout" type="TIMESTAMP"/>
            <column name="parcel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="reroute-token-add-shipment-foreign-key-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="reroute_token"/>
                <tableExists tableName="shipment"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_reroute_token_shipment"/>
                </not>
            </and>
        </preConditions>

        <addForeignKeyConstraint baseTableName="reroute_token"
                                 baseColumnNames="parcel_id"
                                 referencedTableName="shipment"
                                 referencedColumnNames="shipment_id"
                                 constraintName="fk_reroute_token_shipment"/>
    </changeSet>

</databaseChangeLog>
