<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.7.xsd">

    <changeSet id="create-suppliers-table-v2026-2" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="suppliers"/>
            </not>
        </preConditions>

        <createTable tableName="suppliers">
            <column name="supplier_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="supplier_code" type="VARCHAR(50)"/>
            <column name="department_code" type="VARCHAR(255)"/>
            <column name="first_name" type="VARCHAR(100)"/>
            <column name="last_name" type="VARCHAR(100)"/>
            <column name="telephone_number" type="VARCHAR(20)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="user_status" type="VARCHAR(50)"/>
            <column name="vehicle_id" type="BIGINT"/>
            <column name="device_id" type="BIGINT"/>
            <column name="certificate_number" type="VARCHAR(100)"/>
            <column name="issue_date" type="TIMESTAMP"/>
            <column name="expiry_date" type="TIMESTAMP"/>
            <column name="authority" type="VARCHAR(100)"/>
            <column name="valid" type="BOOLEAN"/>
            <column name="driver_license_number" type="VARCHAR(50)"/>
            <column name="acquired_date" type="TIMESTAMP"/>
            <column name="driving_license_expiry_date" type="TIMESTAMP"/>
            <column name="area_name" type="VARCHAR(100)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="district" type="VARCHAR(100)"/>
            <column name="municipality" type="VARCHAR(100)"/>
            <column name="region" type="VARCHAR(100)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="api_key" type="VARCHAR(255)"/>
            <column name="terms_accepted" type="BOOLEAN"/>
            <column name="created_user_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="suppliers-add-department-foreign-key-v2026-2" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="suppliers"/>
                <tableExists tableName="department"/>
                <columnExists tableName="suppliers" columnName="department_code"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_suppliers_department_code"/>
                </not>
            </and>
        </preConditions>

        <addForeignKeyConstraint baseTableName="suppliers"
                                 baseColumnNames="department_code"
                                 referencedTableName="department"
                                 referencedColumnNames="department_code"
                                 constraintName="fk_suppliers_department_code"/>
    </changeSet>

    <changeSet id="create-suppliers-supported-package-types-table-v2026-2" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="suppliers_supported_package_types"/>
            </not>
        </preConditions>

        <createTable tableName="suppliers_supported_package_types">
            <column name="supplier_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="package_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="suppliers_supported_package_types"
                       columnNames="supplier_id, package_type"
                       constraintName="pk_suppliers_supported_package_types"/>
    </changeSet>

    <changeSet id="suppliers-supported-package-types-add-supplier-foreign-key-v2026-2" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="suppliers_supported_package_types"/>
                <tableExists tableName="suppliers"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_suppliers_supported_package_types_supplier"/>
                </not>
            </and>
        </preConditions>

        <addForeignKeyConstraint baseTableName="suppliers_supported_package_types"
                                 baseColumnNames="supplier_id"
                                 referencedTableName="suppliers"
                                 referencedColumnNames="supplier_id"
                                 constraintName="fk_suppliers_supported_package_types_supplier"/>
    </changeSet>

