    </changeSet>

    <changeSet id="create-revinfo-table-v2026-2" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="revinfo"/>
            </not>
        </preConditions>

        <createTable tableName="revinfo">
            <column name="rev" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="revtstmp" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create-suppliers-aud-table-v2026-2" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
