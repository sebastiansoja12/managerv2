<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.7.xsd">

    <changeSet id="create-device-pair-table-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="device_pair"/>
            </not>
        </preConditions>

        <createTable tableName="device_pair">
            <column name="device_pair_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="device_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="paired" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="pair_time" type="TIMESTAMP"/>
            <column name="error_description" type="VARCHAR(255)"/>
            <column name="pair_key" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="create-device-pair-key-index-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="device_pair"/>
                <not>
                    <indexExists tableName="device_pair" indexName="idx_device_pair_pair_key"/>
                </not>
            </and>
        </preConditions>

        <createIndex tableName="device_pair" indexName="idx_device_pair_pair_key">
            <column name="pair_key"/>
        </createIndex>
    </changeSet>

    <changeSet id="add-device-pair-key-expiration-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="device_pair"/>
                <not>
                    <columnExists tableName="device_pair" columnName="pair_key_expires_at"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="device_pair">
            <column name="pair_key_expires_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
