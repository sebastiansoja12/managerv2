        <addForeignKeyConstraint baseTableName="route_log_details"
                                 baseColumnNames="route_log_record_id"
                                 referencedTableName="route_log"
                                 referencedColumnNames="id"
                                 constraintName="fk_route_log_details_route_log"/>
