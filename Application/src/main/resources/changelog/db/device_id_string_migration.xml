    </changeSet>

    <changeSet id="device-id-to-string-v2026-5-add-mobile-apps-fk" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="mobile_installed_apps"/>
                <tableExists tableName="mobiles"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_mobile_installed_apps_device"/>
                </not>
            </and>
        </preConditions>

        <addForeignKeyConstraint baseTableName="mobile_installed_apps"
                                 baseColumnNames="device_id"
                                 referencedTableName="mobiles"
                                 referencedColumnNames="device_id"
                                 constraintName="fk_mobile_installed_apps_device"/>
    </changeSet>

    <changeSet id="device-id-to-string-v2026-5-normalize-mobile-apps-fk-name" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="mobile_installed_apps"/>
                <tableExists tableName="mobiles"/>
                <foreignKeyConstraintExists foreignKeyName="fk_mobile_installed_apps_device"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_mobile_installed_apps_mobile"/>
                </not>
            </and>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="mobile_installed_apps"
                                  constraintName="fk_mobile_installed_apps_device"/>

        <addForeignKeyConstraint baseTableName="mobile_installed_apps"
                                 baseColumnNames="device_id"
                                 referencedTableName="mobiles"
                                 referencedColumnNames="device_id"
                                 constraintName="fk_mobile_installed_apps_mobile"/>
    </changeSet>

</databaseChangeLog>
