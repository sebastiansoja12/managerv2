<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.7.xsd">

    <changeSet id="device-id-to-string-v2026-5-drop-mobile-apps-fk" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="mobile_installed_apps"/>
                <foreignKeyConstraintExists foreignKeyName="fk_mobile_installed_apps_device"/>
            </and>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="mobile_installed_apps"
                                  constraintName="fk_mobile_installed_apps_device"/>
    </changeSet>

    <changeSet id="device-id-to-string-v2026-5-drop-mobile-apps-fk-mobile" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="mobile_installed_apps"/>
                <foreignKeyConstraintExists foreignKeyName="fk_mobile_installed_apps_mobile"/>
            </and>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="mobile_installed_apps"
                                  constraintName="fk_mobile_installed_apps_mobile"/>
    </changeSet>

    <changeSet id="device-id-terminals-to-string-v2026-5" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="terminals" columnName="device_id"/>
        </preConditions>

        <modifyDataType tableName="terminals" columnName="device_id" newDataType="VARCHAR(64)"/>
    </changeSet>

