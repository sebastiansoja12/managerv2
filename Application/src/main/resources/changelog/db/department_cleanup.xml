<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.7.xsd">

    <changeSet id="drop-department-country-column-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="department" columnName="country"/>
        </preConditions>

        <dropColumn tableName="department" columnName="country"/>
    </changeSet>

    <changeSet id="ensure-department-operator-id-column-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="department"/>
                <not>
                    <columnExists tableName="department" columnName="operator_id"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="department">
            <column name="operator_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="ensure-department-aud-operator-id-column-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="department_aud"/>
                <not>
                    <columnExists tableName="department_aud" columnName="operator_id"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="department_aud">
            <column name="operator_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="department-aud-add-revinfo-foreign-key-v2026-3" author="s-soja">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="department_aud"/>
                <tableExists tableName="revinfo"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_department_aud_revinfo"/>
                </not>
            </and>
        </preConditions>

        <addForeignKeyConstraint baseTableName="department_aud"
                                 baseColumnNames="rev"
                                 referencedTableName="revinfo"
                                 referencedColumnNames="rev"
                                 constraintName="fk_department_aud_revinfo"/>
    </changeSet>

</databaseChangeLog>
