<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Change Set to Create the 'redirect_token' Table -->
    <changeSet author="s-soja" id="createRedirectTokenTable">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="redirect_token"/>
            </not>
        </preConditions>

        <createTable tableName="redirect_token">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="timeout" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="parcel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Index on the 'parcel_id' Column -->
    <changeSet author="your_name" id="addParcelIdIndex">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="redirect_token"/>
                <columnExists tableName="redirect_token" columnName="parcel_id"/>
                <not>
                    <indexExists tableName="redirect_token" indexName="IDX_redirect_token_parcel_id"/>
                </not>
            </and>
        </preConditions>

        <createIndex tableName="redirect_token" indexName="IDX_redirect_token_parcel_id" unique="false">
            <column name="parcel_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
