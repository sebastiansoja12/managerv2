FROM maven:3.9.9-eclipse-temurin-21 AS build

WORKDIR /workspace

COPY . .
RUN cd SoftwareConfiguration && mvn -pl SoftwareConfigurationCore -am package -DskipTests

FROM eclipse-temurin:21-jre

COPY --from=build /workspace/SoftwareConfiguration/SoftwareConfigurationCore/target/SoftwareConfigurationCore-2026.3-SNAPSHOT.jar /app.jar

EXPOSE 8081

ENTRYPOINT ["java", "-jar", "/app.jar"]
